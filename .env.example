# adroit environment configuration — example.
#
# Copy this to `.env` (which is git-ignored) and adjust for your machine:
#
#     cp .env.example .env
#
# adroit loads a `.env` from the current directory (or a parent) at startup, so
# these values apply to every command without passing flags. A real shell
# environment variable overrides the `.env` file; a CLI flag overrides both.
#
# Every variable here is OPTIONAL — unset values fall back to the config file
# (~/.config/adroit/config.yaml) and then the built-in defaults.

# Path to the ADR directory adroit operates on. Same as `--dir` / `-d`.
# Point this at your repo's ADR directory:
ADROIT_DIR=/path/to/your-repo/src/adrs

# On-disk format profile. Same as `--format`. One of: markdown | frontmatter
# (default: markdown — MADR-style, status encoded by directory).
# ADROIT_FORMAT=markdown

# Directory layout. Same as `--layout`. One of: by_status | flat | by_category
# (default: by_status — status encoded by directory). `by_category` makes each
# subdirectory an area (status lives in the file), and pairs with
# ADROIT_NAMING=per_category for per-category local numbering.
# ADROIT_LAYOUT=by_status

# TUI markdown-preview color theme. Same as `--theme`. One of: default | gruvbox
# (default: default — 16-color ANSI, respects your terminal palette).
# ADROIT_THEME=gruvbox

# Days after which a still-Proposed ADR with no explicit `review_by` deadline is
# flagged "review due" (in `stats` and the web dashboard). Same as
# `--review-overdue-days`. `0` disables age-based flagging. (default: 30)
# ADROIT_REVIEW_OVERDUE_DAYS=30

# Default template for `new`. Same as `--default-template`. A built-in name
# (madr | nygard) or a path to a custom template. `new --template` overrides it
# per-invocation. (default: madr)
# ADROIT_TEMPLATE=madr

# Where ADR creation/lifecycle dates come from. Same as `--date-source`. One of:
#   auto       — git history when available, else the filesystem (default)
#   git        — require git; warn if it's unavailable or a shallow clone
#   filesystem — never shell git (mtime/authored dates, no lifecycle timeline)
# ADROIT_DATE_SOURCE=auto

# How ADR identifiers and filenames are formed. Same as `--naming`. One of:
#   sequential   — global zero-padded NNNN, `# ADR-NNNN: Title` (default)
#   date         — `YYYYMMDD-title` slug, plain `# Title` (collision-free)
#   uuid         — a persisted UUID (collision-free; not human-sortable)
#   per_category — per-category local NNNN, identity `category/NNNN`
#                  (use with ADROIT_LAYOUT=by_category)
# Pick ONE for the repo's lifetime — adroit doesn't rename existing ADRs when
# you change this. `renumber`/`review` need the sequential scheme.
# ADROIT_NAMING=sequential

# Web dashboard bind address (`adroit serve`, requires the `web` feature).
# Same as `serve --host` (default: 127.0.0.1) and `serve --port` (default: 8080).
# ADROIT_HOST=127.0.0.1
# ADROIT_PORT=8080
