# adroit environment configuration — example.
#
# Copy this to `.env` (which is git-ignored) and adjust for your machine:
#
#     cp .env.example .env
#
# adroit loads a `.env` from the current directory (or a parent) at startup, so
# these values apply to every command without passing flags. A real shell
# environment variable overrides the `.env` file; a CLI flag overrides both.
#
# Every variable here is OPTIONAL — unset values fall back to the config file
# (~/.config/adroit/config.yaml) and then the built-in defaults.

# Path to the ADR directory adroit operates on. Same as `--dir` / `-d`.
# Point this at your repo's ADR directory:
ADROIT_DIR=/path/to/your-repo/src/adrs

# On-disk format profile. Same as `--format`. One of: markdown | frontmatter
# (default: markdown — MADR-style, status encoded by directory).
# ADROIT_FORMAT=markdown

# Directory layout. Same as `--layout`. One of: by_status | flat
# (default: by_status — status encoded by directory).
# ADROIT_LAYOUT=by_status

# TUI markdown-preview color theme. Same as `--theme`. One of: default | gruvbox
# (default: default — 16-color ANSI, respects your terminal palette).
# ADROIT_THEME=gruvbox

# Web dashboard bind address (`adroit serve`, requires the `web` feature).
# Same as `serve --host` (default: 127.0.0.1) and `serve --port` (default: 8080).
# ADROIT_HOST=127.0.0.1
# ADROIT_PORT=8080
